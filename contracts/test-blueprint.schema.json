{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-agent/test-blueprint",
  "title": "QA Agent Test Blueprint",
  "type": "object",
  "required": ["version", "project_name", "created_at", "modules"],
  "properties": {
    "version": { "type": "string", "const": "2.0" },
    "project_name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "knowledge_context_ref": { "type": "string" },
    "summary": { "type": "string" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_id", "title", "goal", "source_refs", "test_points"],
        "properties": {
          "module_id": { "type": "string", "pattern": "^M-[0-9]{2}$" },
          "title": { "type": "string", "minLength": 1 },
          "goal": { "type": "string", "minLength": 1 },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "source_refs": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "test_points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "point_id",
                "title",
                "basis",
                "acceptance_rule",
                "priority",
                "scope",
                "scenarios"
              ],
              "properties": {
                "point_id": { "type": "string", "pattern": "^TP-[0-9]{2}\\.[0-9]{2}$" },
                "title": { "type": "string", "minLength": 1 },
                "basis": { "type": "string", "minLength": 1 },
                "acceptance_rule": { "type": "string", "minLength": 1 },
                "priority": { "enum": ["P0", "P1", "P2", "P3"] },
                "scope": {
                  "type": "object",
                  "required": ["include", "exclude"],
                  "properties": {
                    "include": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1
                    },
                    "exclude": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "platforms": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "entry_points": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "data": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "additionalProperties": false
                },
                "scenarios": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": [
                      "scenario_id",
                      "title",
                      "priority",
                      "type",
                      "preconditions",
                      "test_data",
                      "steps",
                      "expected_results",
                      "postconditions",
                      "execution_channel",
                      "automatable"
                    ],
                    "properties": {
                      "scenario_id": {
                        "type": "string",
                        "pattern": "^S-[0-9]{2}\\.[0-9]{2}\\.[0-9]{2}$"
                      },
                      "title": { "type": "string", "minLength": 1 },
                      "priority": { "enum": ["P0", "P1", "P2", "P3"] },
                      "type": {
                        "enum": ["功能", "边界", "异常", "兼容", "安全", "可访问性", "回归"]
                      },
                      "preconditions": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      },
                      "test_data": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      },
                      "steps": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      },
                      "expected_results": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      },
                      "postconditions": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      },
                      "execution_channel": {
                        "enum": ["browser", "api_intercept", "native_app", "manual"],
                        "description": "browser/api_intercept 供 Playwright 或 agent-browser；native_app/manual 标 automatable=否"
                      },
                      "automatable": { "enum": ["是", "否"] },
                      "automation_note": { "type": "string" },
                      "source_refs": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "derivation": {
                        "type": "object",
                        "description": "推断依据，用于 case-review 审查和分区重跑影响范围判断",
                        "required": ["prd_source", "expected_result_basis", "confidence"],
                        "properties": {
                          "prd_source": {
                            "type": "string",
                            "description": "来自 PRD 哪一段，格式：章节标题 + 关键原文片段"
                          },
                          "figma_source": {
                            "type": "string",
                            "description": "来自 Figma 哪个 frame，可选"
                          },
                          "expected_result_basis": {
                            "type": "string",
                            "description": "预期结果的依据，必须能从 prd_source 或 figma_source 直接引用"
                          },
                          "confidence": {
                            "enum": ["explicit", "inferred"],
                            "description": "explicit=PRD/Figma 原文明确；inferred=AI 根据上下文推断"
                          }
                        },
                        "additionalProperties": false
                      },
                      "covers": {
                        "type": "array",
                        "description": "本场景直接验证的 config 义务项 id 列表。只填这个场景的核心测试目的对应的义务，不要因为场景描述里顺带提到某个词就填进来。纯回归或边界场景可以为空数组。",
                        "items": { "type": "string" }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "impact", "owner", "source_refs"],
        "properties": {
          "id": { "type": "string", "pattern": "^Q-[0-9]{2}$" },
          "question": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "blocking": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
