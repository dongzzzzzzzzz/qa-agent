{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-agent/test-ready-blueprint",
  "title": "Test Ready Blueprint",
  "type": "object",
  "required": [
    "version",
    "project_name",
    "created_at",
    "figma_url",
    "modules",
    "roles",
    "scenarios",
    "assumptions",
    "coverage_matrix",
    "blocking_gaps",
    "delivery_coverage"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "project_name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "figma_url": { "type": "string" },
    "summary": { "type": "string" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "priority"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "figma_nodes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "permissions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "main_flows": { "type": "array" },
    "field_rules": { "type": "array", "items": { "type": "object" } },
    "api_endpoints": { "type": "array", "items": { "type": "object" } },
    "figma_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "prd_section": { "type": "string" },
          "figma_ref": { "type": "string" },
          "frame_names": {
            "type": "array",
            "items": { "type": "string" }
          },
          "note": { "type": "string" }
        }
      }
    },
    "risks": { "type": "array", "items": { "type": "object" } },
    "resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "test_basis"],
        "properties": {
          "id": { "type": "string" },
          "prd_section": { "type": "string" },
          "figma_ref": { "type": "string" },
          "description": { "type": "string" },
          "test_basis": { "enum": ["prd", "figma", "assumption"] },
          "basis_id": { "type": "string" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "test_rule", "risk"],
        "properties": {
          "id": { "type": "string", "pattern": "^ASM-[0-9]{3}$" },
          "statement": { "type": "string", "minLength": 5 },
          "test_rule": { "type": "string", "minLength": 10 },
          "risk": { "enum": ["high", "medium", "low"] },
          "prd_section": { "type": "string" },
          "figma_ref": { "type": "string" }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "module_id",
          "title",
          "type",
          "priority",
          "preconditions",
          "steps",
          "expected",
          "source"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^SC-[0-9]{3}$" },
          "module_id": { "type": "string" },
          "title": { "type": "string" },
          "type": {
            "enum": ["功能", "边界", "异常", "安全", "兼容", "性能"]
          },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "preconditions": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "steps": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "expected": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "source": { "enum": ["prd", "figma", "assumption"] },
          "assumption_id": { "type": "string" },
          "covers_obligations": {
            "type": "array",
            "items": { "type": "string", "pattern": "^O-[0-9]{3}$" },
            "minItems": 1
          },
          "prd_section": { "type": "string" },
          "figma_ref": { "type": "string" }
        }
      }
    },
    "obligations_ref": {
      "type": "string",
      "description": "Path to 00-test-obligations.json when stored separately"
    },
    "coverage_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_id", "functional", "boundary", "exception"],
        "properties": {
          "module_id": { "type": "string" },
          "functional": { "type": "boolean" },
          "boundary": { "type": "boolean" },
          "exception": { "type": "boolean" },
          "security": { "type": "boolean" }
        }
      }
    },
    "blocking_gaps": {
      "type": "array",
      "maxItems": 0,
      "items": { "type": "object" }
    },
    "delivery_coverage": {
      "type": "object",
      "required": [
        "executed_by",
        "project_scale",
        "scenario_minimum_required",
        "prd",
        "figma"
      ],
      "properties": {
        "executed_by": {
          "type": "string",
          "const": "prd-analyzer-subagent"
        },
        "project_scale": {
          "enum": ["small", "medium", "large", "xlarge"]
        },
        "scenario_minimum_required": { "type": "integer", "minimum": 1 },
        "prd": {
          "type": "object",
          "required": [
            "read_complete",
            "sources",
            "sections_inventory",
            "functional_points_count",
            "functional_points_mapped"
          ],
          "properties": {
            "read_complete": { "const": true },
            "sources": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["path", "read_complete"],
                "properties": {
                  "path": { "type": "string" },
                  "pages_total": { "type": "integer", "minimum": 0 },
                  "pages_read": { "type": "integer", "minimum": 0 },
                  "characters": { "type": "integer", "minimum": 0 },
                  "read_complete": { "const": true }
                }
              }
            },
            "sections_inventory": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["section_id", "title", "in_scope"],
                "properties": {
                  "section_id": { "type": "string" },
                  "title": { "type": "string" },
                  "in_scope": { "type": "boolean" },
                  "scenario_ids": {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^SC-[0-9]{3}$" }
                  },
                  "note": { "type": "string" }
                }
              }
            },
            "functional_points_count": { "type": "integer", "minimum": 1 },
            "functional_points_mapped": { "type": "integer", "minimum": 0 }
          }
        },
        "figma": {
          "type": "object",
          "required": ["read_complete", "urls", "frames_inventory"],
          "properties": {
            "read_complete": { "type": "boolean" },
            "urls": { "type": "array", "items": { "type": "string" } },
            "frames_inventory": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "node_id": { "type": "string" },
                  "flow": { "type": "string" },
                  "state_type": {
                    "type": "string",
                    "description": "default|loading|empty|error|disabled|locked 等"
                  },
                  "prd_section": { "type": "string" },
                  "elements_summary": { "type": "string" }
                }
              }
            },
            "note": { "type": "string" }
          }
        }
      }
    }
  }
}
