{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-agent/prd-gate-report",
  "title": "PRD Gate Report",
  "type": "object",
  "required": ["version", "checked_at", "verdict", "issues"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "checked_at": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["pass", "reject"] },
    "reject_kind": {
      "enum": ["product", "internal", "mixed"],
      "description": "product=打回产品; internal=仅回 prd-analyze; mixed=两者皆有"
    },
    "summary": { "type": "string", "minLength": 1 },
    "summary_for_product": {
      "type": "string",
      "description": "面向产品/业务的打回摘要，避免 QA 内部术语"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "dimension",
          "root_cause",
          "audience",
          "retry_target",
          "description",
          "suggestion"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^GATE-[0-9]{3}$" },
          "severity": { "enum": ["blocker", "major", "minor"] },
          "category": { "type": "string", "minLength": 1 },
          "dimension": {
            "enum": ["delivery", "test_point_coverage", "obligation_coverage"]
          },
          "root_cause": {
            "enum": ["prd", "figma", "qa_undercoverage", "assumption_unresolved"]
          },
          "audience": { "enum": ["product", "internal"] },
          "retry_target": { "enum": ["prd-analyze", "product"] },
          "obligation_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^O-[0-9]{3}$" }
          },
          "scenario_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SC-[0-9]{3}$" }
          },
          "description": { "type": "string", "minLength": 10 },
          "product_copy": {
            "type": "object",
            "description": "面向产品读者的说明，render 优先使用",
            "required": ["title", "problem", "action"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 4,
                "description": "短标题，如「租赁频率缺失时，价格怎么显示？」"
              },
              "problem": {
                "type": "string",
                "minLength": 20,
                "description": "问题说明：场景 + 影响，不用 SC/O/ASM 等内部编号"
              },
              "action": {
                "type": "string",
                "minLength": 10,
                "description": "建议修改，可用 - 列表"
              }
            }
          },
          "prd_section": { "type": "string" },
          "figma_ref": { "type": "string" },
          "suggestion": { "type": "string", "minLength": 10 }
        }
      }
    },
    "test_point_review": {
      "type": "object",
      "properties": {
        "coverage_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "obligations_total": { "type": "integer", "minimum": 0 },
        "obligations_p0_uncovered": { "type": "integer", "minimum": 0 },
        "scenarios_total": { "type": "integer", "minimum": 0 },
        "false_coverage_count": { "type": "integer", "minimum": 0 },
        "tri_party": {
          "type": "object",
          "properties": {
            "product": {
              "type": "object",
              "properties": {
                "verdict": { "enum": ["pass", "fail"] },
                "finding_count": { "type": "integer" }
              }
            },
            "dev": {
              "type": "object",
              "properties": {
                "verdict": { "enum": ["pass", "fail"] },
                "finding_count": { "type": "integer" }
              }
            },
            "qa": {
              "type": "object",
              "properties": {
                "verdict": { "enum": ["pass", "fail"] },
                "finding_count": { "type": "integer" }
              }
            },
            "red_team": {
              "type": "object",
              "properties": {
                "verdict": { "enum": ["pass", "fail"] },
                "finding_count": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "false_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "obligation_ids", "reason"],
        "properties": {
          "scenario_id": { "type": "string", "pattern": "^SC-[0-9]{3}$" },
          "obligation_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^O-[0-9]{3}$" }
          },
          "reason": { "type": "string", "minLength": 5 }
        }
      }
    },
    "figma_accessible": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "reject" } }, "required": ["verdict"] },
      "then": {
        "required": ["summary"],
        "properties": {
          "issues": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "verdict": { "const": "pass" } }, "required": ["verdict"] },
      "then": {
        "required": ["summary", "test_point_review", "false_coverage"],
        "properties": {
          "issues": { "maxItems": 0 },
          "false_coverage": { "maxItems": 0 },
          "test_point_review": {
            "required": [
              "coverage_score",
              "obligations_total",
              "obligations_p0_uncovered",
              "scenarios_total",
              "false_coverage_count",
              "tri_party"
            ],
            "properties": {
              "false_coverage_count": { "const": 0 }
            }
          }
        }
      }
    }
  ]
}
