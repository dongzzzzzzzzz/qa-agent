{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-agent/test-obligations",
  "title": "Test Obligations (TOG)",
  "type": "object",
  "required": ["version", "project_name", "created_at", "obligations"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "project_name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "synced_from": { "type": "string" },
    "state_machines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module_id", "states", "transitions"],
        "properties": {
          "id": { "type": "string" },
          "module_id": { "type": "string" },
          "prd_section": { "type": "string" },
          "states": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "trigger"],
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "trigger": { "type": "string" },
                "obligation_id": { "type": "string", "pattern": "^O-[0-9]{3}$" }
              }
            }
          }
        }
      }
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "predicate",
          "source",
          "risk",
          "kind"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^O-[0-9]{3}$" },
          "statement": { "type": "string", "minLength": 5 },
          "predicate": { "type": "string", "minLength": 10 },
          "source": { "enum": ["prd", "figma", "assumption"] },
          "assumption_id": { "type": "string" },
          "risk": { "enum": ["P0", "P1", "P2"] },
          "kind": {
            "enum": [
              "rule",
              "state_transition",
              "combination",
              "nfr",
              "contradiction_candidate"
            ]
          },
          "prd_section": { "type": ["string", "null"] },
          "figma_ref": { "type": ["string", "null"] },
          "module_id": { "type": "string" },
          "covered_by_scenarios": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SC-[0-9]{3}$" }
          }
        }
      }
    }
  }
}
