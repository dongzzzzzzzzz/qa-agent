{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-agent/automation-script",
  "title": "Automation Scripts Directory Manifest",
  "type": "object",
  "required": ["version", "generated_at", "scripts"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "framework": { "enum": ["playwright", "appium", "other"] },
    "scripts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "file"],
        "properties": {
          "case_id": { "type": "string" },
          "file": { "type": "string" },
          "language": { "type": "string" }
        }
      }
    }
  }
}
